{
  "name": "agon-agent-fullstack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:test": "concurrently \"npm run dev:frontend\" \"npm run dev:test:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:test:backend": "cd backend && npm run dev:test",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "build": "concurrently \"cd frontend && npm run build\" \"cd backend && npm run build\"",
    "seed": "cd backend && npm run seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
